# Environment Variables for Pesma Za Tebe
# Copy this file to .env.local and fill in your actual values

# ============================================
# DATABASE (Supabase)
# ============================================
# Get these from https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# OPENAI (ChatGPT API)
# ============================================
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# SUNO AI (Music Generation)
# ============================================
# Get this from https://suno.ai or https://udio.ai
SUNO_API_KEY=your_suno_api_key
SUNO_API_URL=https://api.suno.ai

# ============================================
# ELEVENLABS (Text-to-Speech - Optional)
# ============================================
# Get this from https://elevenlabs.io for dedication voice
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ============================================
# PADDLE (Payment Processing)
# ============================================
# Get these from https://paddle.com
PADDLE_VENDOR_ID=your_vendor_id
PADDLE_API_KEY=your_api_secret_key
PADDLE_WEBHOOK_SECRET=your_webhook_secret
PADDLE_ENVIRONMENT=sandbox  # sandbox or production

# ============================================
# EMAIL (Resend)
# ============================================
# Get this from https://resend.com
RESEND_API_KEY=re-your_resend_api_key
RESEND_FROM_EMAIL=pesme@pesmazgatebe.com

# ============================================
# STORAGE (Cloudflare R2 or Vercel Blob)
# ============================================
# Option 1: Cloudflare R2 (recommended)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=pesmazgatebe-songs
R2_PUBLIC_URL=https://your-custom-domain.com

# Option 2: Vercel Blob
# VERCEL_BLOB_TOKEN=your_vercel_blob_token

# ============================================
# APP SETTINGS
# ============================================
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Pesma Za Tebe

# ============================================
# STRIPE (Alternative payment - Optional)
# ============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_PREMIUM=price_...

# ============================================
# NODE_ENV
# ============================================
NODE_ENV=development